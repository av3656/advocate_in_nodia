<style>
	:root {
		--nav-bg: transparent;
		--text: #0f172a;
		--muted: #475569;
		--drawer-bg: #ffffff;
	}
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.6rem 1rem;
		gap: 1rem;
		margin: 0 auto;
		background: #ffffff;
		box-shadow: 0 2px 8px rgba(2, 6, 23, 0.08);
		z-index: 100;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.drawer-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: transparent;
		border: none;
		padding: 0.25rem;
		margin-right: 0.25rem;
		cursor: pointer;
		color: var(--muted);
	}
	.drawer-toggle:focus {
		outline: 2px solid rgba(59, 130, 246, 0.6);
		border-radius: 6px;
	}
	.brand-title {
		font-weight: 700;
		color: var(--text);
		text-decoration: none;
		font-size: 1.1rem;
	}
	.controls {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.links {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		font-size: 0.8rem;
	}
	.link {
		color: var(--muted);
		text-decoration: none;
		padding: 0.35rem 0.6rem;
		border-radius: 6px;
		font-weight: 600;
	}
	.link:hover {
		background: rgba(15, 23, 42, 0.06);
		color: var(--text);
	}
	.socials {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}
	.social {
		color: var(--muted);
		display: inline-flex;
		align-items: center;
		padding: 0.25rem;
		border-radius: 6px;
	}
	.social:hover {
		background: rgba(15, 23, 42, 0.06);
		color: var(--text);
	}
	.icon {
		width: 20px;
		height: 20px;
		display: block;
	}

	/* Drawer styles */
	.drawer {
		position: fixed;
		right: 0;
		top: 0;
		height: 100vh;
		width: 280px;
		max-width: 85vw;
		background: var(--drawer-bg);
		box-shadow: -2px 0 12px rgba(2, 6, 23, 0.1);
		transform: translateX(110%);
		transition: transform 240ms ease;
		z-index: 50;
		display: flex;
		flex-direction: column;
		padding: 1rem;
	}
	.drawer.open {
		transform: translateX(0%);
	}
	.drawer-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1rem;
	}
	.drawer-close {
		background: transparent;
		border: none;
		font-size: 1.1rem;
		cursor: pointer;
	}
	.drawer-links {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.drawer-link {
		padding: 0.6rem 0.5rem;
		color: var(--text);
		text-decoration: none;
		border-radius: 6px;
		font-weight: 600;
	}
	.drawer-link:hover {
		background: rgba(2, 6, 23, 0.04);
	}

	.drawer-socials {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		margin-top: auto;
		padding-top: 1rem;
		border-top: 1px solid rgba(2, 6, 23, 0.1);
	}

	.drawer-overlay {
		position: fixed;
		inset: 0;
		background: rgba(2, 6, 23, 0.4);
		z-index: 40;
	}

	@media (min-width: 721px) {
		.drawer-toggle {
			display: none;
		}
		.drawer-socials {
			display: none;
		}
	}

	@media (max-width: 720px) {
		.links {
			display: none;
		}
		.socials {
			display: none;
		}
		.brand-title {
			font-size: 0.95rem;
		}
	}
nav ul {
  list-style: none;
  display: flex;
  gap: 2rem;
}

nav ul li {
  position: relative;
}
.services-dropdown-menu {
  position: absolute;
  top: 100%;
  left: 0;
  background: #f3f3f3;
  width: 300px;
  padding: 0;
  margin: 0;
  border-radius: 4px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);

  opacity: 0;
  visibility: hidden;
  transform: translateY(10px);
  transition: all 0.25s ease;
}

.services-dropdown-menu li {
  border-bottom: 1px solid #ddd;
}

.services-dropdown-menu li:last-child {
  border-bottom: none;
}

.services-dropdown-menu a {
  display: block;
  padding: 12px 16px;
  color: #333;
  text-decoration: none;
  font-size: 14px;
}

.services-dropdown-menu a:hover {
  background: #e6e6e6;
}

.services-dropdown:hover .services-dropdown-menu {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}
</style>

<script is:inline>
	(function () {
		const toggle = document.querySelector(".drawer-toggle");
		const drawer = document.querySelector(".drawer");
		const overlay = document.getElementById("drawer-overlay");
		const closeBtn = document.querySelector(".drawer-close");

		function open() {
			drawer.classList.add("open");
			drawer.setAttribute("aria-hidden", "false");
			toggle.setAttribute("aria-expanded", "true");
			overlay.hidden = false;
			document.body.style.overflow = "hidden";
			drawer.querySelector("a")?.focus();
		}

		function close() {
			drawer.classList.remove("open");
			drawer.setAttribute("aria-hidden", "true");
			toggle.setAttribute("aria-expanded", "false");
			overlay.hidden = true;
			document.body.style.overflow = "";
			toggle.focus();
		}

		toggle?.addEventListener("click", open);
		closeBtn?.addEventListener("click", close);
		overlay?.addEventListener("click", close);
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && drawer.classList.contains("open"))
				close();
		});
	})();
</script>
